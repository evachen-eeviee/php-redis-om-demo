{% extends 'base.html.twig' %}

{% block title %}{{ book.title }}{% endblock %}

{% block body %}

    <div class="mb-6">
        <a class="inline-flex items-center text-indigo-600 hover:text-indigo-800 font-medium transition" href="#">
            <svg class="mr-2" xmlns="http://www.w3.org/2000/svg" height="16" width="14" viewBox="0 0 448 512">
              <path fill="currentColor" d="M9.4 233.4c-12.5 12.5-12.5 32.8 0 45.3l160 160c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3L109.2 288 416 288c17.7 0 32-14.3 32-32s-14.3-32-32-32l-306.7 0L214.6 118.6c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0l-160 160z"/>
            </svg>
           Retour au catalogue
    </a>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="md:flex">
            <div class="md:w-1/3 bg-gray-100 flex justify-center items-center p-8">
                <img class="max-h-[400px] shadow-2xl rounded-lg"
                     src="https://placehold.co/400x600/6366f1/ffffff?text={{ book.title }}"
                     alt="Couverture de{{ book.title }}">
            </div>

            <div class="md:w-2/3 p-8 lg:p-12 relative">

                <h1 class="text-4xl font-extrabold text-gray-900 mb-2 leading-tight">
                    {{ book.title }}
                </h1>

                <p class="text-xl text-indigo-600 font-medium mb-8">
                    Par {{ book.author.name }}
                </p>



                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 border-t border-gray-100 pt-8">
                    <div>
                        <h4 class="text-xs text-gray-400 font-bold uppercase tracking-widest mb-1">Catégorie</h4>
                        <p class="text-lg font-semibold text-gray-800"> {{book.category.category}} </p>
                    </div>

                    <div>
                        <h4 class="text-xs text-gray-400 font-bold uppercase tracking-widest mb-1">Prix</h4>
                        <p class="text-lg font-semibold text-gray-800">{{ book.price}} €</p>
                    </div>

                    <div class="md:col-span-2">
                        <h4 class="text-xs text-gray-400 font-bold uppercase tracking-widest mb-2">Description</h4>
                        <p class="text-gray-600 leading-relaxed">
                            {{ book.description }}
                        </p>
                    </div>

                    <div>
                        <h4 class="text-xs text-gray-400 font-bold uppercase tracking-widest mb-1">Publié le</h4>
                        <p class="text-lg font-semibold text-gray-800">{{ book.publishedAt|date('d/m/Y') }}</p>
                    </div>
                </div>

                <div class="mt-10 flex space-x-4">
                    {% if book.enabled == true %}
                        <button class="flex-1 bg-indigo-600 text-white font-bold py-3 px-6 rounded-xl hover:bg-indigo-700 transition shadow-lg shadow-indigo-200">
                            Emprunter l'ouvrage
                        </button>
                    {% else %}
                        <button class="flex-1 bg-red-600 text-white font-bold py-3 px-6 rounded-xl hover:bg-red-700 transition shadow-lg shadow-red-200">
                            Ouvrage Indisponible
                        </button>
                    {% endif %}


                    <a href="{{ path('admin_book_edit', {'id': book.id}) }}" class="bg-gray-100 text-gray-600 py-3 px-6 rounded-xl hover:bg-gray-200 transition font-medium">
                        Modifier
                    </a>
                </div>
            </div>
        </div>
    </div>

<div class="mt-12">
    <h3 class="text-2xl font-bold mb-8 text-gray-800 flex items-center">
        <svg class="w-6 h-6 mr-2 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path>
        </svg>
        Commentaires lecteurs
    </h3>

    {# --- FORMULAIRE DE COMMENTAIRE --- #}
    <div class="bg-gray-50 rounded-2xl p-6 mb-10 border border-gray-200">
        <h4 class="text-lg font-semibold mb-4 text-gray-700">Laisser un avis</h4>

        {{ form_start(form, {'attr': {'class': 'space-y-4'}}) }}
        <div>
            {{ form_label(form.author, 'Votre nom', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.author, {'attr': {'class': 'w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition', 'placeholder': 'Ex: Jean Dupont'}}) }}
            <div class="text-red-500 text-xs mt-1">{{ form_errors(form.author) }}</div>
        </div>

        <div>
            {{ form_label(form.content, 'Votre commentaire', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.content, {'attr': {'class': 'w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition', 'rows': '4', 'placeholder': 'Qu\'avez-vous pensé de cet ouvrage ?'}}) }}
            <div class="text-red-500 text-xs mt-1">{{ form_errors(form.content) }}</div>
        </div>

        <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2.5 px-6 rounded-xl transition shadow-md shadow-indigo-100 flex items-center">
            Publier l'avis
        </button>
        {{ form_end(form) }}
    </div>

    {# --- LISTE DES COMMENTAIRES --- #}
    {#<div class="space-y-6">
        {% for comment in comments %}
            <div class="bg-white rounded-xl p-6 border border-gray-100 shadow-sm transition hover:shadow-md">
                <div class="flex justify-between items-start mb-3">
                    <div class="flex items-center">
                        <div class="h-10 w-10 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-700 font-bold mr-3">
                            {{ comment.author|slice(0, 1)|upper }}
                        </div>
                        <div>
                            <span class="block font-bold text-gray-900">{{ comment.author }}</span>
                            <span class="text-xs text-gray-400">Le {{ comment.createdAt|date('d/m/Y à H:i') }}</span>
                        </div>
                    </div>
                </div>
                <p class="text-gray-600 leading-relaxed">
                    {{ comment.content|nl2br }}
                </p>
            </div>
        {% else %}
            #}{# Message si aucun commentaire #}{#
            <div class="bg-white rounded-xl p-10 border border-dashed border-gray-300 shadow-sm">
                <p class="text-gray-500 italic text-center">Aucun commentaire pour le moment. Soyez le premier à donner votre avis !</p>
            </div>
        {% endfor %}
    </div>#}
</div>
{% endblock %}
